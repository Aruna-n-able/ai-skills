    <wsdl:port name="TokenValidatorSoap12" binding="tns:TokenValidatorSoap12">

      <soap12:address location="http://10.20.2.90/AuthAnvil/SAS.asmx" />
    </wsdl:port>
  </wsdl:service>
</wsdl:definitions>
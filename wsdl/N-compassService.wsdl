          </s:sequence>
        </s:complexType>
      </s:element>
      <s:element name="ExportReady6_7Response">
        <s:complexType>
          <s:sequence>
            <s:element minOccurs="0" maxOccurs="1" name="ExportReady6_7Result" type="tns:ExportInfo"/>
          </s:sequence>
        </s:complexType>
      </s:element>
      <s:complexType name="ExportInfo">
        <s:sequence>
          <s:element minOccurs="0" maxOccurs="1" name="NCompassVersion" type="s:string"/>
          <s:element minOccurs="1" maxOccurs="1" name="ExportReady" type="s:int"/>
          <s:element minOccurs="0" maxOccurs="1" name="info" type="s:string"/>
        </s:sequence>
      </s:complexType>
    </s:schema>

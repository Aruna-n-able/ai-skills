  <wsdl:portType name="AuditorServiceSoap">
    <wsdl:operation name="ExportComplete">
      <wsdl:documentation xmlns:wsdl="http://schemas.xmlsoap.org/wsdl/">Inform N-compass that data export has complete and the ETL may be launched.</wsdl:documentation>
      <wsdl:input message="tns:ExportCompleteSoapIn"/>
      <wsdl:output message="tns:ExportCompleteSoapOut"/>
    </wsdl:operation>
    <wsdl:operation name="RunETL">
      <wsdl:documentation xmlns:wsdl="http://schemas.xmlsoap.org/wsdl/">Runs the ETL for a Single Data source</wsdl:documentation>
      <wsdl:input message="tns:RunETLSoapIn"/>
      <wsdl:output message="tns:RunETLSoapOut"/>
    </wsdl:operation>
    <wsdl:operation name="ExportReady">
      <wsdl:documentation xmlns:wsdl="http://schemas.xmlsoap.org/wsdl/">Inquire if N-compass is ready for an export.</wsdl:documentation>
      <wsdl:input message="tns:ExportReadySoapIn"/>
      <wsdl:output message="tns:ExportReadySoapOut"/>
    </wsdl:operation>
    <wsdl:operation name="ExportReady6_7">
      <wsdl:documentation xmlns:wsdl="http://schemas.xmlsoap.org/wsdl/">Used by N-central 6.7 to get the N-compass version number and query if an export is ready</wsdl:documentation>
      <wsdl:input message="tns:ExportReady6_7SoapIn"/>
      <wsdl:output message="tns:ExportReady6_7SoapOut"/>
    </wsdl:operation>
  </wsdl:portType>

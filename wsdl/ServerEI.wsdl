    <wsdl:portType name="ServerEI_PortType">

        <wsdl:documentation>
            This interface represents the N-central Legacy Web Service - Server External Interface version 1.
        </wsdl:documentation>

        <wsdl:operation name="VersionInfoGet" parameterOrder="Credentials">
            <wsdl:documentation>
                Retrieves the system version information.
                @param credentials the {@link T_Credentials} with the N-able N-central username and the corresponding N-able
                N-central password.
                @return An array of {@link ConfigValue} objects.
                @throws RemoteException if an error occurs.
            </wsdl:documentation>
            <wsdl:input name="VersionInfoGetRequest" message="impl:VersionInfoGetRequest"/>
            <wsdl:output name="VersionInfoGetResponse" message="impl:VersionInfoGetResponse"/>
        </wsdl:operation>

        <wsdl:operation name="RepositoryItemList" parameterOrder="Username Password CustomerID IncludeAncestorItems">
            <wsdl:documentation>
                Retrieves an array of Repository Items based on the specified parameters.
                @param username the valid N-able N-central username.
                @param password the password corresponding to the N-able N-central username.
                @param customerID the customer ID.
                @param includeAncestorItems set to {@code true} if the ancestor items should be included, {@code false}
                otherwise.
                @return An array of {@link RepositoryItem} objects.
                @throws RemoteException if an error occurs.
            </wsdl:documentation>
            <wsdl:input name="RepositoryItemListRequest" message="impl:RepositoryItemListRequest"/>
            <wsdl:output name="RepositoryItemListResponse" message="impl:RepositoryItemListResponse"/>
        </wsdl:operation>

        <wsdl:operation name="RepositoryItemGet" parameterOrder="Username Password RepositoryItemUUID">
            <wsdl:documentation>
                Retrieves a Repository Item with the specified repository item UUID.
                @param username the valid N-able N-central username.
                @param password the password corresponding to the N-able N-central username.
                @param repositoryItemUUID the repository item UUID.
                @return The {@link RepositoryItem} with the specified repository item UUID.
                @throws RemoteException if an error occurs.
            </wsdl:documentation>
            <wsdl:input name="RepositoryItemGetRequest" message="impl:RepositoryItemGetRequest"/>
            <wsdl:output name="RepositoryItemGetResponse" message="impl:RepositoryItemGetResponse"/>
        </wsdl:operation>

        <wsdl:operation name="RepositoryItemGetForCustomer"
                        parameterOrder="Username Password CustomerID RepositoryItemUUID">
            <wsdl:documentation>
                Retrieves a Repository Item with the specified repository item UUID and customer ID.
                @param username the valid N-able N-central username.
                @param password the password corresponding to the N-able N-central username.
                @param customerID the customer ID.
                @param repositoryItemUUID the repository item UUID.
                @return The {@link RepositoryItem} with the specified repository item UUID and customer ID.
                @throws RemoteException if an error occurs.
            </wsdl:documentation>
            <wsdl:input name="RepositoryItemGetForCustomerRequest" message="impl:RepositoryItemGetForCustomerRequest"/>
            <wsdl:output name="RepositoryItemGetResponse" message="impl:RepositoryItemGetResponse"/>
        </wsdl:operation>

        <wsdl:operation name="RepositoryItemPublish"
                        parameterOrder="Username Password CustomerID RepositoryItem Overwrite">
            <wsdl:documentation>
                Publishes the Repository Item for the specified customer ID.
                @param username the valid N-able N-central username.
                @param password the password corresponding to the N-able N-central username.
                @param customerID the customer ID.
                @param repositoryItem the {@link RepositoryItem} to publish.
                @param overwrite set to {@code true} to overwrite, {@code false} otherwise.
                @return The last upload date of the {@link RepositoryItem}.
                @throws RemoteException if an error occurs.

        <wsdl:operation name="DeviceAssetInfoExport2" parameterOrder="Version Username Password">
            <wsdl:documentation>
                Retrieves asset information about all of the devices that are associated with a PSA or an N-able N-central
                sign-in.
                &lt;p&gt;
                Note that this method uses a high-water mark when using PSA credentials. This means that only data that
                is new since the last retrieval will be retrieved. To reset the high-water mark use the LastExportReset
                API.
                &lt;p&gt;
                This is an updated version of the {@link #deviceAssetInfoExport(String, String, String)} method. It
                retrieves a larger set of data and stores retrieved data in a key-value pair format.

                @param version Determines whether N-able N-Central or PSA credentials are to be used. In the case of PSA
                credentials the number indicates the type of PSA integration setup.
                &lt;ul&gt;
                &lt;li&gt;"0.0" indicates that N-able N-central credentials are to be used.&lt;/li&gt;
                &lt;li&gt;"1.0" indicates that a ConnectWise PSA integration is to be used.&lt;/li&gt;
                &lt;li&gt;"2.0" indicates that an Autotask PSA integration is to be used.&lt;/li&gt;
                &lt;li&gt;"3.0" indicates than a Tigerpaw PSA integration is to be used.&lt;/li&gt;
                &lt;/ul&gt;
                @param username the N-able N-central username or a user-defined username for a PSA integration (defined in
                the N-able N-central UI).
                @param password the matching password for the specified username.
                @return An array of {@link Device} objects, each representing one device. Each {@link Device} object
                contains an array of {@link T_KeyPair}s which contain a key ({@link String}) and a value ({@link
                String}). Each {@link T_KeyPair} contains one piece of information about the device. For complete
                details of the return object see documentation for
                {@link #deviceAssetInfoExport2(String, String, String, T_KeyValue[])}.
                @throws RemoteException if there is an error retrieving data from the database.
                @see #deviceAssetInfoExport2(String, String, String, T_KeyValue[])
            </wsdl:documentation>
            <wsdl:input name="DeviceAssetInfoExport2Request" message="impl:DeviceAssetInfoExport2Request"/>
            <wsdl:output name="DeviceAssetInfoExport2Response" message="impl:DeviceAssetInfoExport2Response"/>
        </wsdl:operation>

        <wsdl:operation name="DeviceAssetInfoExport2" parameterOrder="Version Username Password Settings">
            <wsdl:documentation>
                Retrieves asset information about all of the devices that are associated with a PSA or an N-able N-central
                sign-in.
                &lt;p&gt;
                Note that this method uses a high-water mark when using PSA credentials. This means that only data that
                is new since the last retrieval will be retrieved. To reset the high-water mark use the
                LastExportReset API.
                &lt;p&gt;
                This is an updated version of the {@link #deviceAssetInfoExport(String, String, String)} method. It
                retrieves a larger set of data and stores retrieved data in a key-value pair format.
                @param version Determines whether N-able N-Central or PSA credentials are to be used. In the case of PSA
                credentials the number indicates the type of PSA integration setup.
                &lt;ul&gt;
                &lt;li&gt;"0.0" indicates that N-able N-central credentials are to be used.&lt;/li&gt;
                &lt;li&gt;"1.0" indicates that a ConnectWise PSA integration is to be used.&lt;/li&gt;
                &lt;li&gt;"2.0" indicates that an Autotask PSA integration is to be used.&lt;/li&gt;
                &lt;li&gt;"3.0" indicates than a Tigerpaw PSA integration is to be used.&lt;/li&gt;
                &lt;/ul&gt;
                @param username the N-able N-central username or a user-defined username for a PSA integration (defined in
                the N-able N-central UI).
                @param password the matching password for the specified username.
                @param settings (Optional) An array of {@link T_KeyValue} objects each representing one optional setting
                that could be used to limit the amount of data returned. Each {@link T_KeyValue} contains a key
                ({@link String}) and a value ({@link String}[]) i.e the value is an array of {@link String}.
                &lt;br/&gt;&lt;br/&gt;
                &lt;table&gt;
                &lt;caption&gt;Following is the list of keys that can be used in the optionalSettings array&lt;/caption&gt;
                &lt;tbody&gt;
                &lt;tr&gt;
                &lt;td&gt;&lt;b&gt;Use only ONE of the following options to limit information to certain devices&lt;/b&gt;&lt;/td&gt;
                &lt;td&gt;&amp;nbsp;&lt;/td&gt;
                &lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;"TargetByDeviceID" - value for this key is an array of deviceids&lt;/td&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;"TargetByDeviceName" - value for this key is an array of devicenames&lt;/td&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;"TargetByFilterID" - value for this key is an array of filterids&lt;/td&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;"TargetByFilterName" - value for this key is an array filternames&lt;/td&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;
                &lt;td&gt;&lt;b&gt;Use only ONE of the following options to limit information by including or excluding
                certain information category&lt;/b&gt;&lt;/td&gt;
                &lt;td&gt;&amp;nbsp;&lt;/td&gt;
                &lt;/tr&gt;
                &lt;tr&gt;
                &lt;td&gt;"InformationCategoriesInclusion" - value for this key is an array of information category to
                include&lt;/td&gt;
                &lt;td&gt;&amp;nbsp;&lt;/td&gt;
                &lt;/tr&gt;
                &lt;tr&gt;
                &lt;td&gt;e.g. in {@link T_KeyValue} if (Key) = "InformationCategoriesInclusion" and
                (Value) = {@link String}[] {"asset.device", "asset.os"} then only information for these two
                categories will be returned.&lt;/td&gt;
                &lt;td&gt;&amp;nbsp;&lt;/td&gt;
                &lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;
                &lt;td&gt;"InformationCategoriesExclusion" - value for this key is an array of information category to
                exclude&lt;/td&gt;
                &lt;td&gt;&amp;nbsp;&lt;/td&gt;
                &lt;/tr&gt;
                &lt;tr&gt;
                &lt;td&gt;e.g. in {@link T_KeyValue} if key = "InformationCategoriesExclusion" and
                value = {@link String}[] {"asset.device", "asset.os"} then information for these two categories will
                be excluded.&lt;/td&gt;
                &lt;td&gt;&amp;nbsp;&lt;/td&gt;
                &lt;/tr&gt;
                &lt;tr&gt;
                &lt;td&gt;
                &lt;table&gt;
                &lt;caption&gt;List of information category that could be used&lt;/caption&gt;
                &lt;tbody&gt;
                &lt;tr&gt;
                &lt;td&gt;
                &lt;ul&gt;
                &lt;li&gt;"asset.device" Device.&lt;/li&gt;
                &lt;li&gt;"asset.os" OS.&lt;/li&gt;
                &lt;li&gt;"asset.computersystem" Computer System.&lt;/li&gt;
                &lt;li&gt;"asset.processor" Processor.&lt;/li&gt;
                &lt;li&gt;"asset.motherboard" Motherboard.&lt;/li&gt;
                &lt;li&gt;"asset.raidcontroller" Raid Controller.&lt;/li&gt;
                &lt;li&gt;"asset.memory" Memory.&lt;/li&gt;
                &lt;li&gt;"asset.videocontroller" Video Controller.&lt;/li&gt;
                &lt;li&gt;"asset.logicaldevice" Logical Device.&lt;/li&gt;
                &lt;li&gt;"asset.physicaldrive" Physical Drive.&lt;/li&gt;
                &lt;li&gt;"asset.mappeddrive" Mapped Drive.&lt;/li&gt;
                &lt;li&gt;"asset.mediaaccessdevice" Media Access Device.&lt;/li&gt;
                &lt;li&gt;"asset.networkadapter" Network Adapter.&lt;/li&gt;
                &lt;li&gt;"asset.usbdevice" USB Device.&lt;/li&gt;
                &lt;li&gt;"asset.printer" Printer.&lt;/li&gt;
                &lt;li&gt;"asset.port" Port.&lt;/li&gt;
                &lt;li&gt;"asset.service" Service.&lt;/li&gt;
                &lt;li&gt;"asset.application" Application.&lt;/li&gt;
                &lt;li&gt;"asset.patch" Patch.&lt;/li&gt;
                &lt;li&gt;"asset.customer" Customer.&lt;/li&gt;
                &lt;li&gt;"asset.socustomer" Service Organization.&lt;/li&gt;
                &lt;/ul&gt;
                &lt;/td&gt;
                &lt;/tr&gt;
                &lt;/tbody&gt;
                &lt;/table&gt;
                &lt;/td&gt;
                &lt;td&gt;&amp;nbsp;&lt;/td&gt;
                &lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;&lt;b&gt;To request information later than a specific date time value&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;
                &lt;td&gt;"TargetByTimestamp" - a time in the format yyyy-mm-dd hh:mm:ss (e.g. 2012-12-31 23:59:59).
                Only one value could be specified.&lt;/td&gt;
                &lt;td&gt;&amp;nbsp;&lt;/td&gt;
                &lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;td&gt;&amp;nbsp;&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;
                &lt;td&gt;&lt;b&gt;To request information as link to a file to download instead of an array of

            <wsdl:output name="RepositoryItemPublishResponse" message="impl:RepositoryItemPublishResponse"/>
        </wsdl:operation>

        <wsdl:operation name="AcknowledgeNotification"
                        parameterOrder="ActiveNotificationTriggerIDArray CorrelatedProfileIDArray Username Password Note AddToDeviceNotes SuppressOnEscalation">
            <wsdl:documentation>
                Allows notifications within N-able N-central to be acknowledged. It provides access to all of the optional
                functionality available in the N-central UI such as suppressing further notifications on acknowledgment.
                @param activeNotificationTriggerIDArray (Optional) This is a unique identifier of the notification that
                can be found in the XML notification. Either this field or {@code correlatedProfileIDArray} must be
                populated.
                @param correlatedProfileIDArray (Optional) This is a unique identifier of the correlated notification
                that can be found in the XML notification. Either this field or {@code activeNotificationTriggerIDArray}
                must be populated.
                @param username the username of an N-able N-central UI user.
                @param password the password of an N-able N-central UI user.
                @param note (Optional) A note can be added with the acknowledgement.
                @param addToDeviceNotes (Optional) The above note can be added to the notes for the device.
                @param suppressOnEscalation (Optional) Suppress further notifications.
                @throws RemoteException if there is an error retrieving data from the database.
                &lt;p&gt;
                org.apache.axis.AxisFault
                &lt;ul&gt;
                &lt;li&gt;2003 - PSA integration disabled or unlicensed.&lt;/li&gt;
                &lt;li&gt;5000 - An unexpected exception occurred.&lt;/li&gt;
                &lt;/ul&gt;
            </wsdl:documentation>
            <wsdl:input name="AcknowledgeNotificationRequest" message="impl:AcknowledgeNotificationRequest"/>
            <wsdl:output name="AcknowledgeNotificationResponse" message="impl:AcknowledgeNotificationResponse"/>
        </wsdl:operation>

        <wsdl:operation name="DeviceAssetInfoExport" parameterOrder="Version Username Password">
            <wsdl:documentation>
                It is used by third-party applications to connect to the N-able N-central web service (SOAP) interface and
                obtain a list of device configuration information. The {@code nableURL} field in the structure returned
                by the API call can be used for single-sign-on deep linking to the &lt;b&gt;Properties&lt;/b&gt; tab of
                the device details screen. To use this API, you must sign in to the N-able N-central Administrative
                Console (NAC) and configure the interaction by specifying the customers whose device information will
                be returned by the API as well as the credentials that will be used in order to access the API.
                &lt;p&gt;
                This method will always return information on devices that have been changed since the last call. This
                is referred to as the "high water mark". Refer to LastExportReset to reset the "high water mark".
                Additionally, information will be returned on devices that have also been deleted. In the case of
                deleted devices, only the deviceID and Deleted fields will be populated.
                @param version Indicates the type of PSA integration setup. The list below are valid inputs
                &lt;ul&gt;
                &lt;li&gt;"1.0" indicates that a ConnectWise PSA integration is to be used.&lt;/li&gt;
                &lt;li&gt;"2.0" indicates that an Autotask PSA integration is to be used.&lt;/li&gt;
                &lt;li&gt;"3.0" indicates than a Tigerpaw PSA integration is to be used.&lt;/li&gt;
                &lt;/ul&gt;
                @param username the user-specified PSA integration username.
                @param password the corresponding password.
                @return An array of {@link DeviceData} objects which contain the asset data of a device. The
                {@link DeviceData} object contains the following information: &lt;br/&gt;&lt;br/&gt;
                &lt;table&gt;
                &lt;col width="25%"/&gt;&lt;col width="75%"/&gt;
                &lt;thead&gt;
                &lt;tr&gt;&lt;th&gt;Fieldname&lt;/th&gt;&lt;th&gt;Description&lt;/th&gt;&lt;/tr&gt; &lt;/thead&gt;
                &lt;tbody&gt;
                &lt;tr&gt;&lt;td&gt;deviceID&lt;/td&gt;&lt;td&gt;The unique N-able N-central ID of the device.&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;deleted&lt;/td&gt;&lt;td&gt;Indicates if the device has been flagged for deletion.&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;installationDate&lt;/td&gt;&lt;td&gt;Indicates the date that the device became
                managed by N-able N-central.&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;IPAddress&lt;/td&gt;&lt;td&gt;The device's URI.&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;deviceClass&lt;/td&gt;&lt;td&gt;The N-able N-central class of the device.&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;OS_ReportedOS&lt;/td&gt;&lt;td&gt;The device's reported operating system
                (CIM_OperatingSystem.reportedos).&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;
                &lt;td&gt;OS_ServicePackVersion&lt;/td&gt;
                &lt;td&gt;The version of the service pack being used by the device (CIM_OperatingSystem.csdversion).&lt;/td&gt;
                &lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;OS_Version&lt;/td&gt;&lt;td&gt;The version of the device's operating system
                (CIM_OperatingSystem.version).&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;computerName&lt;/td&gt;&lt;td&gt;The identifying name of the device
                (Device.LongName).&lt;/td&gt;&lt;/tr&gt;
                &lt;tr&gt;
                &lt;td&gt;physicalMemoryBytes&lt;/td&gt;
                &lt;td&gt;The size of the device's physical memory (CIM_ComputerSystem.totalphysicalmemory)&lt;/td&gt;
                &lt;/tr&gt;
                &lt;tr&gt;
                &lt;td&gt;computerSystemManufacturer&lt;/td&gt;
                &lt;td&gt;The name of the manufacturer of the device (CIM_ComputerSystem.manufacturer).&lt;/td&gt;
                &lt;/tr&gt;
                &lt;tr&gt;&lt;td&gt;computerSystemProductModel&lt;/td&gt;&lt;td&gt;The model name of the device
                (CIM_ComputerSystem.model).&lt;/td&gt;&lt;/tr&gt;
